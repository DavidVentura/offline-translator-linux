# Maintainer: David <david@davidv.dev>
pkgname=offline-translator-linux
pkgver=0.1.0
pkgrel=0
pkgdesc="On-device offline translator built with Slint"
url="https://github.com/DavidVentura/offline-translator-linux"
arch="aarch64 x86_64"
license="GPL-3.0-or-later"
depends="
	libpulse
	libstdc++
	mesa-gl
	qt5-qtbase
	qt5-qtdeclarative
"
makedepends="
	bash
	cargo
	clang-dev
	clang-libclang
	cmake
	git
	linux-headers
	mesa-dev
	pkgconf
	pulseaudio-dev
	python3
	qt5-qtbase-dev
	qt5-qtdeclarative-dev
	rust
	samurai
"
# For pmaports submission, replace the local tarball with:
#   $pkgname-$pkgver.tar.gz::https://github.com/DavidVentura/offline-translator-linux/archive/refs/tags/v$pkgver.tar.gz
source="
	$pkgname-$pkgver.tar.gz
	offline-translator-linux.desktop
"
builddir="$srcdir/$pkgname-$pkgver"
options="net !check"

prepare() {
	default_prepare
	export CARGO_NET_GIT_FETCH_WITH_CLI=true
	cargo fetch --target="$CHOST" --locked
}

build() {
	export CARGO_NET_GIT_FETCH_WITH_CLI=true
	export CMAKE_POLICY_VERSION_MINIMUM=3.5
	cargo build --frozen --release --target="$CHOST"
}

package() {
	install -Dm755 \
		target/"$CHOST"/release/offline-translator-linux \
		"$pkgdir"/usr/bin/offline-translator-linux

	install -Dm755 \
		runtime-lib/"$CARCH"/libonnxruntime.so \
		"$pkgdir"/usr/lib/libonnxruntime.so

	install -Dm644 \
		"$srcdir"/offline-translator-linux.desktop \
		"$pkgdir"/usr/share/applications/offline-translator-linux.desktop

	install -Dm644 \
		clickable/assets/logo.png \
		"$pkgdir"/usr/share/icons/hicolor/512x512/apps/offline-translator-linux.png
}
sha512sums="
